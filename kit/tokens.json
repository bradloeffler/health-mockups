{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "FORGE design tokens. Warm-charcoal dark theme with amber accents. iOS 430-mobile-first.",
  "color": {
    "bg":           { "$value": "#16140f", "$type": "color", "$description": "App background, warm near-black" },
    "surface":      { "$value": "#1a1814", "$type": "color", "$description": "Default card surface" },
    "raised":       { "$value": "#1f1c16", "$type": "color", "$description": "Raised surface (popovers, accent cards)" },
    "deep":         { "$value": "#0d0c0a", "$type": "color", "$description": "Deepest well (nav backing, modal scrim)" },
    "hair":         { "$value": "#2c281f", "$type": "color", "$description": "Hairline divider" },
    "hair-strong":  { "$value": "#3a3528", "$type": "color", "$description": "Stronger hairline (active states)" },
    "ink":          { "$value": "#efeae0", "$type": "color", "$description": "Primary text, warm bone" },
    "sub":          { "$value": "#a59d8d", "$type": "color", "$description": "Secondary text" },
    "faint":        { "$value": "#6f6859", "$type": "color", "$description": "Tertiary / eyebrow / unit" },
    "amber":        { "$value": "#e3a857", "$type": "color", "$description": "Primary brand accent" },
    "amber-bright": { "$value": "#f3c378", "$type": "color", "$description": "Hover / active amber" },
    "amber-dim":    { "$value": "#7a5a2c", "$type": "color", "$description": "Pressed / hairline accent" },
    "on-amber":     { "$value": "#1a1206", "$type": "color", "$description": "Text on amber surface" },
    "green":        { "$value": "#4fd17e", "$type": "color", "$description": "Recovery / success" },
    "blue":         { "$value": "#6fb0d8", "$type": "color", "$description": "Strain / info" },
    "red":          { "$value": "#e0664a", "$type": "color", "$description": "Warning / overage" },
    "yellow":       { "$value": "#e6c14e", "$type": "color", "$description": "Caution" }
  },
  "space": {
    "0": { "$value": "4px",  "$type": "dimension" },
    "1": { "$value": "8px",  "$type": "dimension" },
    "2": { "$value": "12px", "$type": "dimension" },
    "3": { "$value": "16px", "$type": "dimension" },
    "4": { "$value": "20px", "$type": "dimension" },
    "5": { "$value": "24px", "$type": "dimension" },
    "6": { "$value": "32px", "$type": "dimension" },
    "7": { "$value": "40px", "$type": "dimension" },
    "8": { "$value": "56px", "$type": "dimension" }
  },
  "radius": {
    "sm":   { "$value": "8px",   "$type": "dimension" },
    "md":   { "$value": "12px",  "$type": "dimension" },
    "lg":   { "$value": "16px",  "$type": "dimension" },
    "xl":   { "$value": "20px",  "$type": "dimension" },
    "pill": { "$value": "999px", "$type": "dimension" }
  },
  "type": {
    "family": {
      "ui":   { "$value": "-apple-system, \"Helvetica Neue\", Arial, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "ui-monospace, \"SF Mono\", \"Courier New\", monospace", "$type": "fontFamily" }
    },
    "eyebrow":  { "$value": { "fontSize": "10px", "fontWeight": 600, "letterSpacing": "0.16em", "lineHeight": 1.2,  "textTransform": "uppercase" }, "$type": "typography" },
    "label":    { "$value": { "fontSize": "13px", "fontWeight": 500, "letterSpacing": "0",       "lineHeight": 1.3 }, "$type": "typography" },
    "body":     { "$value": { "fontSize": "15px", "fontWeight": 500, "letterSpacing": "0",       "lineHeight": 1.4 }, "$type": "typography" },
    "title":    { "$value": { "fontSize": "28px", "fontWeight": 300, "letterSpacing": "-0.4px",  "lineHeight": 1.15 }, "$type": "typography" },
    "num-sm":   { "$value": { "fontSize": "14px", "fontWeight": 500, "letterSpacing": "-0.2px",  "lineHeight": 1.0 }, "$type": "typography" },
    "num-md":   { "$value": { "fontSize": "18px", "fontWeight": 500, "letterSpacing": "-0.3px",  "lineHeight": 1.0 }, "$type": "typography" },
    "num-lg":   { "$value": { "fontSize": "22px", "fontWeight": 400, "letterSpacing": "-0.4px",  "lineHeight": 1.0 }, "$type": "typography" },
    "num-xl":   { "$value": { "fontSize": "28px", "fontWeight": 300, "letterSpacing": "-0.6px",  "lineHeight": 1.0 }, "$type": "typography" }
  },
  "shadow": {
    "card":   { "$value": "0 1px 0 rgba(255,255,255,0.02) inset, 0 8px 24px rgba(0,0,0,0.35)", "$type": "shadow" },
    "raised": { "$value": "0 1px 0 rgba(255,255,255,0.03) inset, 0 12px 36px rgba(0,0,0,0.5)", "$type": "shadow" },
    "nav":    { "$value": "0 10px 40px rgba(0,0,0,0.6), 0 1px 0 rgba(255,255,255,0.04) inset", "$type": "shadow" },
    "glow-amber": { "$value": "0 0 24px rgba(227,168,87,0.18), 0 0 0 1px rgba(227,168,87,0.25) inset", "$type": "shadow" }
  },
  "motion": {
    "fast":   { "$value": "120ms cubic-bezier(0.2, 0.0, 0.2, 1)", "$type": "duration" },
    "base":   { "$value": "200ms cubic-bezier(0.2, 0.0, 0.2, 1)", "$type": "duration" },
    "slow":   { "$value": "320ms cubic-bezier(0.2, 0.0, 0.2, 1)", "$type": "duration" }
  }
}
